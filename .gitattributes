# Default text normalization
* text=auto

# Windows scripts and project files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.filters text eol=crlf
*.props text eol=crlf
*.rc text eol=crlf
*.manifest text eol=crlf

# Source and config files
*.cpp text
*.c text
*.h text
*.hpp text
*.inl text
*.cmake text
CMakeLists.txt text
*.md text
*.txt text
*.json text
*.yml text
*.yaml text

# Binary assets and build outputs
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.lib binary
*.pdb binary
